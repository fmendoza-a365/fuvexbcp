# ══════════════════════════════════════════════════
# Fuvex Manager — Variables de Entorno
# ══════════════════════════════════════════════════

# Servidor
PORT=3001
NODE_ENV=production

# Seguridad — IMPORTANTE: Genera un secreto único y largo
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generar_un_secreto_largo_y_seguro_aqui

# Base de Datos (SQLite local)
DATABASE_URL="file:./dev.db"

# CORS — Orígenes permitidos (separar por coma si hay varios)
# En desarrollo: http://localhost:3001,http://localhost:5173
# Con Ngrok: agregar el dominio de tu tunnel
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,https://yodel-thumb-veggie.ngrok-free.dev

# Integración Infoburo (Scraping RCC)
# ⚠️ NUNCA subas este archivo al repositorio
INFOBURO_USER=tu_usuario
INFOBURO_PASS=tu_password

