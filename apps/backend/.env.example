# Fuvex Manager - backend environment

PORT=3001
NODE_ENV=production

# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_unique_64_byte_secret

# Keep production databases outside the repository tree when using SQLite.
# For Docker Compose, /app/data/prod.db is mounted from ./data.
DATABASE_URL="file:../../../data/prod.db"

# Comma-separated allowed origins.
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Infoburo credentials. Never commit real values.
INFOBURO_USER=replace_me
INFOBURO_PASS=replace_me
