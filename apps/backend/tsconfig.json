{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": [
      "node"
    ],
    "noImplicitAny": false
  },
  "include": [
    "src/**/*",
    "prisma/**/*"
  ]
}