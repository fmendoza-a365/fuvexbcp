{
  "expo": {
    "name": "Fvx365",
    "slug": "fvxa365",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fmendozaa365.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fmendozaa365.mobile"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiUrl": "",
      "eas": {
        "projectId": "7c0674be-1380-412b-8203-724220952712"
      }
    },
    "owner": "fmendoza-a365"
  }
}
